{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Tenovo Hjälpcenter",
  "description": "Guider och dokumentation för att komma igång och få ut det mesta av Tenovo.",
  "colors": {
    "primary": "#166E3F",
    "light": "#26BD6C",
    "dark": "#166E3F"
  },
  "favicon": "/favicon.svg",
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  },
  "contextual": {
    "options": ["copy", "view", "assistant"]
  },
  "navigation": {
    "global": {
      "anchors": [
        {
          "anchor": "Hem",
          "icon": "house",
          "href": "/"
        },
        {
          "anchor": "Tenovo-appen",
          "icon": "external-link",
          "href": "https://app.tenovo.se"
        }
      ]
    },
    "directory": "card",
    "groups": [
      {
        "group": "Kom igång",
        "icon": "rocket",
        "expanded": true,
        "pages": [
          "kom-igang"
        ]
      },
      {
        "group": "Fastigheter & hyresobjekt",
        "icon": "building-2",
        "expanded": true,
        "pages": [
          "fastigheter/oversikt",
          "fastigheter/lagga-till-fastighet",
          "fastigheter/hyresobjekt"
        ]
      },
      {
        "group": "Hyresgäster",
        "icon": "users",
        "expanded": true,
        "pages": [
          "hyresgaster/oversikt",
          "hyresgaster/lagga-till-hyresgast",
          "hyresgaster/bjuda-in-till-portalen"
        ]
      },
      {
        "group": "Hyreskontrakt",
        "icon": "file-text",
        "expanded": true,
        "pages": [
          "avtal/oversikt",
          "avtal/skapa-hyreskontrakt",
          "avtal/signera-med-bankid",
          "avtal/avtalsmallar"
        ]
      },
      {
        "group": "Hyror & betalningar",
        "icon": "banknote",
        "expanded": true,
        "pages": [
          "hyror/oversikt",
          "hyror/skapa-hyra",
          "hyror/betalningsstatus"
        ]
      },
      {
        "group": "Kalender",
        "icon": "calendar",
        "expanded": true,
        "pages": [
          "kalender/oversikt",
          "kalender/synkronisering"
        ]
      },
      {
        "group": "Inställningar",
        "icon": "settings",
        "expanded": true,
        "pages": [
          "installningar/oversikt",
          "installningar/avtalsparter",
          "installningar/medlemmar",
          "installningar/integrationer"
        ]
      },
      {
        "group": "Säkerhet & efterlevnad",
        "icon": "shield",
        "expanded": true,
        "pages": [
          "sakerhet/datahantering"
        ]
      },
      {
        "group": "Support",
        "icon": "headset",
        "expanded": true,
        "pages": [
          "support"
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [],
    "primary": {
      "type": "button",
      "label": "Öppna Tenovo",
      "href": "https://app.tenovo.se"
    }
  },
  "footer": {
    "socials": {
      "linkedin": "https://linkedin.com/company/tenovo"
    }
  }
}
